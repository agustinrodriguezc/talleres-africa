    { "name": "CUSTOMERS",          "module": "CRM",        "color": "#1d4ed8", "key_attrs": ["customer_id PK", "type", "tax_id", "payment_terms_days"],               "description": "Workshop clients — individuals and companies. payment_terms_days is the root cause of the 104-day collection period." },
    { "name": "VEHICLES",           "module": "CRM",        "color": "#1d4ed8", "key_attrs": ["plate PK", "customer_id FK", "brand", "model", "km_entry"],             "description": "Registered vehicles. Licence plate as PK — natural identifier in the sector. Tracks mileage to build maintenance history." },
    { "name": "WORK_ORDERS",        "module": "Operations", "color": "#166534", "key_attrs": ["wo_id PK", "plate FK", "status", "open_date", "rework"],                 "description": "Central document of the AIS. 6-state lifecycle: Open → Authorised → In Progress → Pending Validation → Ready → Closed." },
    { "name": "REPORTS",            "module": "Operations", "color": "#166534", "key_attrs": ["report_id PK", "type", "generated_date", "wo_id FK", "period"],          "description": "Auto-generated management reports. Linked to Work Orders (operational) and Sales Invoices (financial). Feeds the KPI Dashboard and BSC in real time." },
    { "name": "EMPLOYEES",          "module": "Catalogue",  "color": "#6b21a8", "key_attrs": ["employee_id PK", "category_id FK", "cost_hour_eur", "billing_rate_eur"], "description": "NEW entity. Without it the system cannot calculate real WO cost or measure productivity per technician." },
    { "name": "SERVICE_CATEGORIES", "module": "Catalogue",  "color": "#6b21a8", "key_attrs": ["category_id PK", "category_name", "billing_rate_eur", "cost_rate_eur"],  "description": "6 service areas with billing and cost rates. Feeds the analytical chart of accounts (accounts 7050–7055)." },
    { "name": "SERVICES",           "module": "Catalogue",  "color": "#6b21a8", "key_attrs": ["service_id PK", "service_name", "category_id FK", "standard_time_h"],   "description": "Service catalogue with standard execution time. Deviation from actual time is the primary operational KPI." },
    { "name": "SUPPLIERS",          "module": "Purchasing", "color": "#c2410c", "key_attrs": ["supplier_id PK", "company_name", "payment_terms_days", "discount_pct"],  "description": "Parts suppliers. payment_terms_days drives the DPO — currently 52 days vs 104-day collection period." },
    { "name": "PRODUCTS",           "module": "Purchasing", "color": "#c2410c", "key_attrs": ["product_id PK", "sku", "supplier_id FK", "stock_units", "stock_min"],    "description": "Parts catalogue with stock levels and reorder points. Current stock: €108,681. Turnover: 11.08x." },
    { "name": "PURCHASE_ORDERS",    "module": "Purchasing", "color": "#c2410c", "key_attrs": ["po_id PK", "supplier_id FK", "order_date", "status"],                    "description": "Purchase orders. Tracks items in transit — ordered but not yet received." },
    { "name": "PO_LINES",           "module": "Purchasing", "color": "#c2410c", "key_attrs": ["po_line_id PK", "po_id FK", "product_id FK", "ordered_qty", "received_qty"], "description": "Line items per purchase order. Detects partial deliveries and enables three-way matching." },
    { "name": "STOCK",              "module": "Purchasing", "color": "#c2410c", "key_attrs": ["stock_id PK", "product_id FK", "wo_id FK", "movement_type", "quantity", "movement_date"], "description": "Inventory movements ledger. Records stock-in (PO receipt) and stock-out (WO consumption). Enables real-time stock control and automatic reorder alerts." },
    { "name": "SALES_INVOICES",     "module": "Invoicing",  "color": "#9d174d", "key_attrs": ["invoice_id PK", "wo_id FK", "customer_id FK", "due_date", "payment_status"], "description": "NEW entity — separate from Work Order. Tracks collection status and due dates. Target: 104 → 60 days." }
  ],

