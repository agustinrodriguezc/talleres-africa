  "problems": [
    {
      "id": "P1",
      "title": "No internal accounting management",
      "type": "Structural",
      "severity": "CRITICAL",
      "icon": "🏗️",
      "evidence_short": "100% outsourced — zero internal reporting",
      "evidence_detail": "All accounting delegated to external advisory firm. No management reports, no analytical accounting, no budget vs. actual comparison. The company navigates €1.2M of revenue on experience and intuition alone.",
      "impact_eur": null,
      "impact_label": "Opportunity cost not directly quantifiable",
      "david_quote": null,
      "ais_solution": "Analytical accounting module + management reporting layer — P&L by service area, monthly closing in <2 hours"
    },
    {
      "id": "P2",
      "title": "No traceability: diagnosis → invoice",
      "type": "Internal Control",
      "severity": "CRITICAL",
      "icon": "⛓️",
      "evidence_short": "Oral approvals, no formal Work Orders",
      "evidence_detail": "The entire process runs verbally — diagnosis communicated orally, budget approved verbally, invoice reconstructed from memory. No document links diagnosis to final invoice.",
      "impact_eur": null,
      "impact_label": "Risk of under-billing and client disputes",
      "david_quote": "Si yo no estoy, Moisés no sabe qué le hemos prometido a según qué clientes. Nos ha pasado facturar dos veces el mismo trabajo a un cliente de flota y tener que hacer una nota de crédito con todo el lío que eso genera.",
      "ais_solution": "Formal Work Order with mandatory prior digital authorisation — 6-state lifecycle: Open → Authorised → In Progress → Pending Validation → Ready → Closed"
    },
    {
      "id": "P3",
      "title": "104-day collection period",
      "type": "Financial",
      "severity": "CRITICAL",
      "icon": "⏰",
      "evidence_short": "€348,010 trapped in unpaid invoices",
      "evidence_detail": "Average collection of 104 days vs. 52-day payment period creates a 52-day funding gap. The company self-finances this gap with short-term bank credit costing €14,147/year — 39% of net profit.",
      "impact_eur": 14147,
      "impact_label": "€14,147/year in financial expenses (39% of net profit)",
      "david_quote": null,
      "ais_solution": "Accounts receivable module with automatic due date alerts, debtor ageing panel, and proactive follow-up workflow"
    },
    {
      "id": "P4",
      "title": "Operational silos between departments",
      "type": "Organisational",
      "severity": "HIGH",
      "icon": "🧱",
      "evidence_short": "5 types of silos identified",
      "evidence_detail": "Reception promises delivery times without checking workshop load. Parts delays not communicated proactively. Extra work billed without prior customer approval. Knowledge stored in individual mechanics' memory. Communication via WhatsApp and oral channels with no central record.",
      "impact_eur": null,
      "impact_label": "Customer loss and trust erosion — not yet quantified",
      "david_quote": null,
      "ais_solution": "CRM module + real-time WO status Kanban + automatic delay notifications + centralised communication log"
    },
    {
      "id": "P5",
      "title": "No analytical cost control",
      "type": "Strategic",
      "severity": "HIGH",
      "icon": "📊",
      "evidence_short": "Materials = 73.3% of revenue, no area breakdown",
      "evidence_detail": "€883,308 in materials consumed (SABI 2024) with no breakdown by service area. €184,665 in staff costs with no allocation by work type. The company does not know which of its 4 service areas is profitable.",
      "impact_eur": null,
      "impact_label": "Incorrect pricing and service mix decisions",
      "david_quote": null,
      "ais_solution": "Cost centre accounting: CC01 Mechanics, CC02 Bodywork & Paint, CC03 Tyres, CC04 Multimedia — costs allocated via WO_Lines hours"
    },
    {
      "id": "P6",
      "title": "Stock managed by visual inspection",
      "type": "Operational",
      "severity": "MEDIUM",
      "icon": "📦",
      "evidence_short": "€108,681 inventory with no reorder system",
      "evidence_detail": "Stock control performed visually and empirically. No automated reorder points. In 2024, the workshop had to stop a paint booth twice due to out-of-stock epoxy primer while waiting for urgent delivery from Tecnauto.",
      "impact_eur": null,
      "impact_label": "Risk of stockouts + excess tied-up capital",
      "david_quote": null,
      "ais_solution": "Stock module with configurable reorder points and automatic replenishment alerts per SKU"
    }
  ],

